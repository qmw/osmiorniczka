---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const faq = [
  { question: "Na co mozna przeznaczyc kredyt inwestycyjny?", answer: "Na zakup srodkow trwalych: nieruchomosci, maszyn, linii technologicznych, pojazdow. Rowniez na budowe, rozbudowe lub modernizacje obiektow." },
  { question: "Jaki jest okres splacania kredytu inwestycyjnego?", answer: "Typowo 5-15 lat, w przypadku nieruchomosci nawet do 20-25 lat. Dluzszy okres niz w kredycie obrotowym." },
  { question: "Czy potrzebuje wkladu wlasnego?", answer: "Tak, zazwyczaj 15-30% wartosci inwestycji. Wklad wlasny moze pochodzic ze srodkow wlasnych lub z dotacji." }
];
---
<ServiceLayout
  title="Kredyt Inwestycyjny dla Firm 2026 — Maszyny, Nieruchomosci | Osmiorniczka"
  description="Kredyt inwestycyjny dla firm — na zakup maszyn, nieruchomosci, rozbudowe. Dlugi okres splacania, z gwarancja BGK. Porownaj oferty bankow."
  h1="Kredyt inwestycyjny — sfinansuj rozwoj firmy"
  subtitle="Kredyt na zakup maszyn, nieruchomosci lub modernizacje. Dlugi okres splacania do 20 lat, z mozliwoscia gwarancji BGK."
  breadcrumbParent={{ name: "Kredyty", url: "/kredyty/obrotowy/" }}
  breadcrumbCurrent="Kredyt inwestycyjny"
  faq={faq}
>
  <h2>Kredyt inwestycyjny — kiedy lepszy niz leasing?</h2>
  <p>Kredyt inwestycyjny to dobra alternatywa dla leasingu, gdy:</p>
  <ul>
    <li>Chcesz byc <strong>wlascicielem od pierwszego dnia</strong></li>
    <li>Inwestujesz w <strong>nieruchomosci</strong> (leasing nieruchomosci jest mniej popularny)</li>
    <li>Potrzebujesz <strong>dluzszego okresu splacania</strong> (10-25 lat)</li>
    <li>Wartoszc inwestycji jest <strong>bardzo wysoka</strong> (powyzej 1 mln zl)</li>
  </ul>
  <h3>Wymagane dokumenty</h3>
  <ul>
    <li>Sprawozdania finansowe za ostatnie 2 lata</li>
    <li>Biznesplan lub opis inwestycji</li>
    <li>Prognozy finansowe</li>
    <li>Dokumenty rejestrowe firmy</li>
    <li>Wycena lub kosztorys inwestycji</li>
  </ul>
</ServiceLayout>
