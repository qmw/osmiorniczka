---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const faq = [
  { question: "Na co można przeznaczyć kredyt inwestycyjny?", answer: "Na zakup środków trwałych: nieruchomości, maszyn, linii technologicznych, pojazdów. Również na budowę, rozbudowę lub modernizację obiektów." },
  { question: "Jaki jest okres spłacania kredytu inwestycyjnego?", answer: "Typowo 5-15 lat, w przypadku nieruchomości nawet do 20-25 lat. Dłuższy okres niż w kredycie obrotowym." },
  { question: "Czy potrzebuję wkładu własnego?", answer: "Tak, zazwyczaj 15-30% wartości inwestycji. Wkład własny może pochodzić ze środków własnych lub z dotacji." }
];
---
<ServiceLayout
  title="Kredyt Inwestycyjny dla Firm 2026 — Maszyny, Nieruchomości | Ośmiorniczka"
  description="Kredyt inwestycyjny dla firm — na zakup maszyn, nieruchomości, rozbudowę. Długi okres spłacania, z gwarancją BGK. Porównaj oferty banków."
  h1="Kredyt inwestycyjny — sfinansuj rozwój firmy"
  subtitle="Kredyt na zakup maszyn, nieruchomości lub modernizację. Długi okres spłacania do 20 lat, z możliwością gwarancji BGK."
  breadcrumbParent={{ name: "Kredyty", url: "/kredyty/" }}
  breadcrumbCurrent="Kredyt inwestycyjny"
  faq={faq}
>
  <h2>Kredyt inwestycyjny — kiedy lepszy niż leasing?</h2>
  <p>Kredyt inwestycyjny to dobra alternatywa dla leasingu, gdy:</p>
  <ul>
    <li>Chcesz być <strong>właścicielem od pierwszego dnia</strong></li>
    <li>Inwestujesz w <strong>nieruchomości</strong> (leasing nieruchomości jest mniej popularny)</li>
    <li>Potrzebujesz <strong>dłuższego okresu spłacania</strong> (10-25 lat)</li>
    <li>Wartość inwestycji jest <strong>bardzo wysoka</strong> (powyżej 1 mln zł)</li>
  </ul>
  <h3>Wymagane dokumenty</h3>
  <ul>
    <li>Sprawozdania finansowe za ostatnie 2 lata</li>
    <li>Biznesplan lub opis inwestycji</li>
    <li>Prognozy finansowe</li>
    <li>Dokumenty rejestrowe firmy</li>
    <li>Wycena lub kosztorys inwestycji</li>
  </ul>
</ServiceLayout>
