---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const faq = [
  { question: "Co to jest kredyt obrotowy?", answer: "Kredyt obrotowy sluzy do finansowania biezacej dzialalnosci firmy — wyplat, zakupu towarow, oplacenia faktur. Mozesz wielokrotnie wyplacac i splacac srodki w ramach przyznanego limitu." },
  { question: "Jaka jest roznica miedzy kredytem obrotowym a inwestycyjnym?", answer: "Obrotowy finansuje biezaca dzialalnosc (kapital obrotowy), inwestycyjny — zakupy srodkow trwalych (maszyny, nieruchomosci). Obrotowy jest bardziej elastyczny, inwestycyjny ma dluzszy okres splacania." },
  { question: "Czy nowa firma moze dostac kredyt obrotowy?", answer: "To trudniejsze niz leasing, ale mozliwe — zwlaszcza z gwarancja BGK de minimis. Minimum 3-6 miesiecy dzialalnosci." },
  { question: "Ile trwa uzyskanie kredytu obrotowego?", answer: "W bankach online 1-3 dni, w tradycyjnych bankach 1-3 tygodnie. Z gwarancja BGK moze byc dluzej." }
];
---
<ServiceLayout
  title="Kredyt Obrotowy dla Firm 2026 — Porownaj Oferty Bankow | Osmiorniczka"
  description="Kredyt obrotowy dla firm — porownaj oferty bankow. Finansowanie biezacej dzialalnosci, elastyczny limit, z gwarancja BGK. Bezplatna konsultacja."
  h1="Kredyt obrotowy dla firm — porownaj oferty bankow"
  subtitle="Potrzebujesz kapitalu obrotowego? Porownamy oferty bankow i pomozemy uzyskac najlepsze warunki. Rowniez z gwarancja BGK de minimis."
  breadcrumbParent={{ name: "Kredyty", url: "/kredyty/obrotowy/" }}
  breadcrumbCurrent="Kredyt obrotowy"
  faq={faq}
>
  <h2>Kredyt obrotowy — do czego sluzy?</h2>
  <p>Kredyt obrotowy to jedno z podstawowych narzedzi finansowania biezacej dzialalnosci firmy. Pozwala na:</p>
  <ul>
    <li>Regulowanie <strong>zobowiazan wobec dostawcow</strong></li>
    <li>Finansowanie <strong>zakupu towarow i materialow</strong></li>
    <li>Pokrycie <strong>kosztow stalych</strong> w slabszych miesiącach</li>
    <li>Utrzymanie <strong>plynnosci finansowej</strong></li>
  </ul>
  <h3>Rodzaje kredytu obrotowego</h3>
  <table>
    <thead><tr><th>Rodzaj</th><th>Opis</th><th>Dla kogo</th></tr></thead>
    <tbody>
      <tr><td>Linia kredytowa (odnawialny)</td><td>Limit do wielokrotnego wykorzystania</td><td>Firmy z regularnymi wahaniami</td></tr>
      <tr><td>Kredyt w rachunku</td><td>Debet na koncie firmowym</td><td>Krotkoterminowe potrzeby</td></tr>
      <tr><td>Kredyt na fakture</td><td>Finansowanie pod konkretna fakture</td><td>Firmy z dlugimi terminami platnosci</td></tr>
      <tr><td>Kredyt celowy</td><td>Jednorazowa wyplata na konkretny cel</td><td>Wieksze zakupy towarow</td></tr>
    </tbody>
  </table>
  <h3>Gwarancja BGK de minimis</h3>
  <p>Gwarancja BGK de minimis to <strong>bezplatne zabezpieczenie kredytu</strong> przez Bank Gospodarstwa Krajowego. Pokrywa do 80% kwoty kredytu i znaczaco ulatwia uzyskanie finansowania — szczegolnie dla mniejszych firm.</p>
</ServiceLayout>
