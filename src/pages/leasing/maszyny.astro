---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const faq = [
  { question: "Jakie maszyny mozna leasingowac?", answer: "Praktycznie kazde — CNC, budowlane (koparki, ladowarki), rolnicze (traktory, kombajny), produkcyjne, medyczne, poligraficzne. Kazdy srodek trwaly o wartosci powyzej kilku tysiecy zlotych." },
  { question: "Czy moge leasingowac uzywane maszyny?", answer: "Tak, wiele firm leasingowych finansuje uzywane maszyny. Kluczowe jest udokumentowanie stanu technicznego i wartosci rynkowej (wycena rzeczoznawcy)." },
  { question: "Jaki jest minimalny wklad wlasny?", answer: "Od 0% do 20% w zaleznosci od rodzaju maszyny, jej wieku i kondycji finansowej Twojej firmy. Nowe maszyny od uznanych producentow — nawet 0%." },
  { question: "Czy moge odliczyc 100% VAT od leasingu maszyn?", answer: "Tak — w przeciwienstwie do samochodow osobowych, przy maszynach odliczasz 100% VAT od kazdej raty leasingowej. Cala rata netto jest kosztem uzyskania przychodu." }
];
---

<ServiceLayout
  title="Leasing Maszyn i Urzadzen 2026 — CNC, Budowlane, Rolnicze | Osmiorniczka"
  description="Leasing maszyn i urzadzen dla firm — CNC, budowlane, rolnicze, produkcyjne. Porownaj oferty, od 0% wkladu. 100% VAT w odliczeniu. Bezplatna konsultacja."
  h1="Leasing maszyn i urzadzen — najlepsze oferty 2026"
  subtitle="Finansujemy kazdy rodzaj maszyn: CNC, budowlane, rolnicze, produkcyjne, medyczne. Od 0% wkladu, 100% VAT do odliczenia."
  breadcrumbParent={{ name: "Leasing", url: "/leasing/samochody/" }}
  breadcrumbCurrent="Maszyny i urzadzenia"
  faq={faq}
>
  <h2>Leasing maszyn — dlaczego sie oplaca?</h2>
  <p>Leasing maszyn i urzadzen to jeden z najkorzystniejszych sposobow finansowania inwestycji w srodki trwale. W przeciwienstwie do samochodow osobowych, <strong>nie ma limitu wartosci</strong> — cala rata netto jest kosztem i odliczasz <strong>100% VAT</strong>.</p>

  <h3>Jakie maszyny finansujemy?</h3>
  <ul>
    <li><strong>Obrabiarki CNC</strong> — tokarki, frezarki, centra obrobcze</li>
    <li><strong>Maszyny budowlane</strong> — koparki, ladowarki, dzwigi, betoniarki</li>
    <li><strong>Maszyny rolnicze</strong> — traktory, kombajny, siewniki, opryskiwacze</li>
    <li><strong>Maszyny produkcyjne</strong> — linie produkcyjne, roboty przemyslowe</li>
    <li><strong>Sprzet medyczny</strong> — USG, RTG, tomografy, stoly operacyjne</li>
    <li><strong>Maszyny poligraficzne</strong> — drukarki offsetowe, plotery, bigowki</li>
  </ul>

  <h3>Korzysci leasingu maszyn vs kredyt</h3>
  <table>
    <thead>
      <tr><th>Aspekt</th><th>Leasing</th><th>Kredyt</th></tr>
    </thead>
    <tbody>
      <tr><td>VAT</td><td>Rozlozony na raty</td><td>Caly z gory</td></tr>
      <tr><td>Bilans</td><td>Pozabilansowy (operacyjny)</td><td>Wchodzi w zadluzenie</td></tr>
      <tr><td>Koszty</td><td>Cala rata = koszt</td><td>Tylko odsetki = koszt</td></tr>
      <tr><td>Wklad wlasny</td><td>Od 0%</td><td>Zwykle 20%+</td></tr>
      <tr><td>Szybkosc decyzji</td><td>24-48h</td><td>2-4 tygodnie</td></tr>
    </tbody>
  </table>

  <h3>Leasing maszyn uzywanych</h3>
  <p>Finansujemy rowniez uzywane maszyny. Wymagania to zazwyczaj:</p>
  <ul>
    <li>Wycena rzeczoznawcy lub faktura od sprzedawcy</li>
    <li>Maszyna nie starsza niz 10-15 lat na koniec umowy</li>
    <li>Sprawnosc techniczna potwierdzona przegladem</li>
    <li>Wklad wlasny 10-20% (wyzszy niz dla nowych)</li>
  </ul>
</ServiceLayout>
