---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm';
---

<BaseLayout
  title="Leasing dla Firm — Samochody, Maszyny, IT, Fotowoltaika | Ośmiorniczka"
  description="Wszystko o leasingu dla firm. Porównaj rodzaje leasingu, sprawdź warunki dla różnych aktywów i oblicz ratę. Darmowa wiedza bez zobowiązań."
>
  <!-- Breadcrumbs -->
  <nav class="bg-white border-b border-slate-100 py-3" aria-label="Breadcrumb">
    <div class="container-wide">
      <ol class="flex items-center gap-2 text-sm text-slate-500">
        <li><a href="/" class="hover:text-teal-600 transition-colors">Strona główna</a></li>
        <li><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></li>
        <li class="text-slate-800 font-medium">Leasing</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="py-12 md:py-20" style="background: linear-gradient(135deg, #D1F5F4 0%, #FAFBFC 100%);">
    <div class="container-wide max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-slate-900 mb-4">Leasing dla firm</h1>
      <p class="text-lg text-slate-600 mb-6">Leasing to najpopularniejsza forma finansowania środków trwałych w Polsce. Cała rata w kosztach firmy, VAT rozłożony na raty, decyzja nawet w 24 godziny. Poniżej znajdziesz wszystko, czego potrzebujesz — od poradników po kalkulator.</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/kalkulator-leasingu" class="btn-primary">Oblicz ratę leasingu</a>
        <a href="/blog/jak-wziac-leasing-na-firme/" class="btn-secondary">Jak wziąć leasing? — poradnik</a>
      </div>
    </div>
  </section>

  <!-- Co możesz leasingować -->
  <section class="section-padding bg-white">
    <div class="container-wide">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-slate-900 mb-8 text-center">Co możesz leasingować?</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <a href="/leasing/samochody/" class="card group">
          <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-teal-100 transition-colors">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h.844c.525 0 1.033-.19 1.428-.535l2.406-2.1a2.25 2.25 0 011.48-.555h3.692a2.25 2.25 0 011.575.645l2.7 2.7a2.25 2.25 0 001.59.66h1.33a.75.75 0 01.75.75v1.51a1.125 1.125 0 01-1.125 1.125h-.87"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2 group-hover:text-teal-600 transition-colors">Samochody</h3>
          <p class="text-sm text-slate-500 mb-3">Osobowe, dostawcze, ciężarowe, elektryczne, używane. Od 0% wkładu własnego.</p>
          <span class="text-sm font-semibold text-teal-600 inline-flex items-center gap-1">Dowiedz się więcej <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></span>
        </a>

        <a href="/leasing/maszyny/" class="card group">
          <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-teal-100 transition-colors">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.049.58.025 1.194-.14 1.743"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2 group-hover:text-teal-600 transition-colors">Maszyny i urządzenia</h3>
          <p class="text-sm text-slate-500 mb-3">CNC, budowlane, rolnicze, produkcyjne, medyczne. 100% VAT do odliczenia.</p>
          <span class="text-sm font-semibold text-teal-600 inline-flex items-center gap-1">Dowiedz się więcej <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></span>
        </a>

        <a href="/leasing/it-sprzet/" class="card group">
          <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-teal-100 transition-colors">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2 group-hover:text-teal-600 transition-colors">Sprzęt IT</h3>
          <p class="text-sm text-slate-500 mb-3">Komputery, serwery, drukarki, oprogramowanie. Regularna wymiana bez dużych wydatków.</p>
          <span class="text-sm font-semibold text-teal-600 inline-flex items-center gap-1">Dowiedz się więcej <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></span>
        </a>

        <a href="/leasing/fotowoltaika/" class="card group">
          <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-teal-100 transition-colors">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2 group-hover:text-teal-600 transition-colors">Fotowoltaika</h3>
          <p class="text-sm text-slate-500 mb-3">Panele słoneczne, magazyny energii, pompy ciepła. Rata często niższa niż rachunek za prąd.</p>
          <span class="text-sm font-semibold text-teal-600 inline-flex items-center gap-1">Dowiedz się więcej <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></span>
        </a>

        <a href="/leasing/nieruchomosci/" class="card group">
          <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-teal-100 transition-colors">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2 group-hover:text-teal-600 transition-colors">Nieruchomości</h3>
          <p class="text-sm text-slate-500 mb-3">Biura, hale, magazyny. Alternatywa dla kredytu hipotecznego, bez hipoteki.</p>
          <span class="text-sm font-semibold text-teal-600 inline-flex items-center gap-1">Dowiedz się więcej <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></span>
        </a>

        <a href="/leasing/zwrotny/" class="card group">
          <div class="w-12 h-12 bg-coral-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-coral-100 transition-colors">
            <svg class="w-6 h-6 text-coral-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2 group-hover:text-teal-600 transition-colors">Leasing zwrotny</h3>
          <p class="text-sm text-slate-500 mb-3">Uwolnij gotówkę z posiadanych środków trwałych. Szybki zastrzyk kapitału.</p>
          <span class="text-sm font-semibold text-teal-600 inline-flex items-center gap-1">Dowiedz się więcej <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <!-- Operacyjny vs finansowy -->
  <section class="section-padding bg-[#FAFBFC]">
    <div class="container-narrow">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-slate-900 mb-4 text-center">Leasing operacyjny vs finansowy</h2>
      <p class="text-center text-slate-500 mb-8 max-w-2xl mx-auto">Dwa rodzaje, różne zasady podatkowe. Który jest lepszy? To zależy od Twojej sytuacji.</p>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="bg-teal-50 text-teal-800 font-semibold px-4 py-3 text-left rounded-tl-lg">Kryterium</th>
              <th class="bg-teal-50 text-teal-800 font-semibold px-4 py-3 text-left">Operacyjny</th>
              <th class="bg-teal-50 text-teal-800 font-semibold px-4 py-3 text-left rounded-tr-lg">Finansowy</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <tr><td class="px-4 py-3 font-medium text-slate-800">Rata w kosztach</td><td class="px-4 py-3 text-slate-600">Cała rata netto</td><td class="px-4 py-3 text-slate-600">Tylko odsetki</td></tr>
            <tr><td class="px-4 py-3 font-medium text-slate-800">VAT</td><td class="px-4 py-3 text-slate-600">Rozłożony na raty</td><td class="px-4 py-3 text-slate-600">Cały z góry</td></tr>
            <tr><td class="px-4 py-3 font-medium text-slate-800">Własność</td><td class="px-4 py-3 text-slate-600">Leasingodawca</td><td class="px-4 py-3 text-slate-600">Ty (ekonomicznie)</td></tr>
            <tr><td class="px-4 py-3 font-medium text-slate-800">Wykup</td><td class="px-4 py-3 text-slate-600">Opcjonalny (1-15%)</td><td class="px-4 py-3 text-slate-600">Automatyczny</td></tr>
            <tr><td class="px-4 py-3 font-medium text-slate-800">Dla kogo lepszy</td><td class="px-4 py-3 text-slate-600">Większość firm</td><td class="px-4 py-3 text-slate-600">Chcący być właścicielem</td></tr>
          </tbody>
        </table>
      </div>

      <div class="text-center mt-6">
        <a href="/blog/leasing-operacyjny-vs-finansowy/" class="text-teal-600 font-semibold hover:text-teal-800 transition-colors inline-flex items-center gap-1">
          Przeczytaj pełne porównanie
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Przydatne artykuły -->
  <section class="section-padding bg-white">
    <div class="container-wide">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-slate-900 mb-8 text-center">Przydatne poradniki</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/blog/jak-wziac-leasing-na-firme/" class="card group">
          <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Jak wziąć leasing na firmę?</h3>
          <p class="text-sm text-slate-500">Krok po kroku — od wniosku do odbioru przedmiotu.</p>
        </a>
        <a href="/blog/ile-kosztuje-leasing-samochodu/" class="card group">
          <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Ile kosztuje leasing samochodu?</h3>
          <p class="text-sm text-slate-500">Przykładowe raty, ukryte koszty, limity podatkowe.</p>
        </a>
        <a href="/blog/jakie-dokumenty-do-leasingu/" class="card group">
          <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Jakie dokumenty do leasingu?</h3>
          <p class="text-sm text-slate-500">Lista dokumentów per forma prawna — JDG, sp. z o.o., S.A.</p>
        </a>
        <a href="/blog/leasing-bez-wkladu-wlasnego/" class="card group">
          <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Leasing bez wkładu własnego</h3>
          <p class="text-sm text-slate-500">Czy 0% wpłaty jest możliwe? Warunki i koszty.</p>
        </a>
        <a href="/blog/co-mozna-wziac-w-leasing/" class="card group">
          <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Co można wziąć w leasing?</h3>
          <p class="text-sm text-slate-500">Pełna lista — od aut po fotowoltaikę.</p>
        </a>
        <a href="/blog/jak-wybrac-firme-leasingowa/" class="card group">
          <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Jak wybrać firmę leasingową?</h3>
          <p class="text-sm text-slate-500">7 kryteriów porównania i red flags.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-[#FAFBFC]">
    <div class="container-narrow">
      <div class="bg-gradient-to-br from-teal-50 via-white to-coral-50 rounded-3xl border border-slate-200 p-8 md:p-12 text-center">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-slate-900 mb-3">Masz pytanie o leasing?</h2>
        <p class="text-slate-500 mb-6">Napisz — chętnie pomożemy. Zero zobowiązań.</p>
        <div class="max-w-lg mx-auto">
          <ContactForm client:visible variant="compact" />
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://leasingpoprostu.pl/" },
      { "@type": "ListItem", "position": 2, "name": "Leasing", "item": "https://leasingpoprostu.pl/leasing/" }
    ]
  })} />
</BaseLayout>
