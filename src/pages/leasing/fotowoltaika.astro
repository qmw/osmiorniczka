---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const faq = [
  { question: "Czy leasing fotowoltaiki się opłaca?", answer: "Tak — raty leasingowe są często niższe niż oszczędności na rachunkach za prąd. Dodatkowo cała rata jest kosztem firmy i odliczasz 100% VAT." },
  { question: "Czy mogę połączyć leasing z dotacją?", answer: "W niektórych programach tak. Doradzimy, które opcje dotacji (np. Mój Prąd dla firm, programy wojewódzkie) można łączyć z leasingiem." },
  { question: "Jaki jest okres leasingu fotowoltaiki?", answer: "Typowo 36-72 miesięcy. Długi okres pozwala uzyskać niską ratę — często niższą niż dotychczasowy rachunek za energię." }
];
---
<ServiceLayout
  title="Leasing Fotowoltaiki dla Firm 2026 — Panele, Magazyny Energii | Ośmiorniczka"
  description="Leasing fotowoltaiki dla firm — panele słoneczne, magazyny energii, pompy ciepła. Rata niższa niż rachunek za prąd. 100% VAT w odliczeniu."
  h1="Leasing fotowoltaiki dla firm — obniż rachunki za energię"
  subtitle="Zainstaluj fotowoltaikę bez zamrażania kapitału. Rata leasingu często niższa niż dotychczasowy rachunek za prąd. 100% w kosztach firmy."
  breadcrumbParent={{ name: "Leasing", url: "/leasing/" }}
  breadcrumbCurrent="Fotowoltaika"
  faq={faq}
>
  <h2>Fotowoltaika na leasing — dlaczego warto?</h2>
  <p>Instalacja fotowoltaiczna to inwestycja, która zwraca się w 5-8 lat. Dzięki leasingowi nie musisz wykładać 50 000-200 000 zł z góry — <strong>raty często są niższe niż oszczędności na prądzie</strong>.</p>
  <h3>Co możesz sfinansować?</h3>
  <ul>
    <li><strong>Panele fotowoltaiczne</strong> — instalacje dachowe i gruntowe</li>
    <li><strong>Magazyny energii</strong> — baterie litowe, systemy hybrydowe</li>
    <li><strong>Pompy ciepła</strong> — powietrzne i gruntowe</li>
    <li><strong>Turbiny wiatrowe</strong> — małe elektrownie wiatrowe</li>
  </ul>
  <h3>Korzyści podatkowe leasingu fotowoltaiki</h3>
  <ul>
    <li>Cała rata netto = <strong>koszt uzyskania przychodu</strong></li>
    <li><strong>100% VAT</strong> do odliczenia (fotowoltaika to nie samochód!)</li>
    <li>Brak limitu wartości</li>
    <li>Amortyzacja po stronie leasingodawcy (leasing operacyjny)</li>
  </ul>
  <h3>Przykład kalkulacji</h3>
  <table>
    <thead><tr><th>Parametr</th><th>Wartość</th></tr></thead>
    <tbody>
      <tr><td>Instalacja</td><td>50 kWp</td></tr>
      <tr><td>Koszt netto</td><td>150 000 zł</td></tr>
      <tr><td>Rata leasingu (60 mies.)</td><td>ok. 3 100 zł/mies.</td></tr>
      <tr><td>Oszczędność na prądzie</td><td>ok. 3 500 zł/mies.</td></tr>
      <tr><td>Bilans miesięczny</td><td>+400 zł na Twoją korzyść</td></tr>
    </tbody>
  </table>
</ServiceLayout>
