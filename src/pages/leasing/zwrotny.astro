---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const faq = [
  { question: "Co to jest leasing zwrotny?", answer: "Leasing zwrotny polega na sprzedaży posiadanego środka trwałego firmie leasingowej i jednoczesnym wzięciu go w leasing. Efekt: odzyskujesz gotówkę zamrożoną w środku trwałym, ale nadal z niego korzystasz." },
  { question: "Jakie aktywa mogą być przedmiotem leasingu zwrotnego?", answer: "Samochody, maszyny, sprzęt IT, nieruchomości — praktycznie każdy środek trwały o udokumentowanej wartości." },
  { question: "Czy leasing zwrotny się opłaca?", answer: "Tak, jeśli potrzebujesz szybkiego zastrzyku gotówki bez zaciągania kredytu. Kosztem jest oprocentowanie leasingu, ale zyskujesz płynność finansową." }
];
---
<ServiceLayout
  title="Leasing Zwrotny 2026 — Uwolnij Gotówkę z Posiadanych Aktywów | Ośmiorniczka"
  description="Leasing zwrotny — sprzedaj posiadane środki trwałe firmie leasingowej i nadal z nich korzystaj. Szybki zastrzyk gotówki bez kredytu. Porównaj oferty."
  h1="Leasing zwrotny — uwolnij gotówkę z posiadanych aktywów"
  subtitle="Potrzebujesz gotówki? Sprzedaj posiadane środki trwałe firmie leasingowej i nadal z nich korzystaj. Szybki zastrzyk kapitału bez kredytu."
  breadcrumbParent={{ name: "Leasing", url: "/leasing/" }}
  heroImage="/leasing-zwrotny-hero.png"
  breadcrumbCurrent="Leasing zwrotny"
  faq={faq}
>
  <h2>Jak działa leasing zwrotny?</h2>
  <ol>
    <li><strong>Wycena</strong> — rzeczoznawca wycenia Twój środek trwały (auto, maszynę, nieruchomość)</li>
    <li><strong>Sprzedaż</strong> — sprzedajesz go firmie leasingowej za wartość rynkową</li>
    <li><strong>Leasing</strong> — bierzesz ten sam środek w leasing zwrotny</li>
    <li><strong>Gotówka</strong> — otrzymujesz środki na konto (zwykle 70-90% wartości)</li>
    <li><strong>Korzystasz dalej</strong> — używasz go tak jak dotychczas</li>
    <li><strong>Wykup</strong> — po zakończeniu umowy wykupujesz z powrotem</li>
  </ol>
  <h3>Kiedy warto rozważyć leasing zwrotny?</h3>
  <ul>
    <li>Potrzebujesz <strong>szybkiego zastrzyku gotówki</strong></li>
    <li>Nie chcesz zaciągać kredytu obrotowego</li>
    <li>Masz cenne środki trwałe "zamrożone" w bilansie</li>
    <li>Chcesz <strong>poprawić wskaźniki finansowe</strong> (bilans)</li>
    <li>Szukasz finansowania na rozwój firmy</li>
  </ul>
</ServiceLayout>
