---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm';
---

<BaseLayout
  title="Kontakt — Bezpłatna Konsultacja Leasingowa | Ośmiorniczka"
  description="Skontaktuj się z nami — bezpłatna konsultacja leasingowa i kredytowa. Oddzwonimy w 15 minut. Telefon, email, formularz kontaktowy."
>
  <section class="section-padding bg-[#FAFBFC]">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-heading font-bold text-slate-900 mb-4">Porozmawiajmy o Twoim finansowaniu</h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto">Bezpłatna konsultacja, bez zobowiązań. Oddzwonimy w ciągu 15 minut w godzinach pracy.</p>
      </div>

      <div class="grid lg:grid-cols-5 gap-8 max-w-5xl mx-auto">
        <!-- Contact info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-teal-50 rounded-lg flex-shrink-0 flex items-center justify-center">
                <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-slate-800 mb-1">Telefon</h3>
                <a href="tel:+48000000000" class="text-teal-600 font-mono font-medium hover:text-teal-800">+48 XXX XXX XXX</a>
                <p class="text-sm text-slate-500 mt-1">pon-pt, 8:00 - 18:00</p>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-teal-50 rounded-lg flex-shrink-0 flex items-center justify-center">
                <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-slate-800 mb-1">Email</h3>
                <a href="mailto:kontakt@leasingpoprostu.pl" class="text-teal-600 font-medium hover:text-teal-800">kontakt@leasingpoprostu.pl</a>
                <p class="text-sm text-slate-500 mt-1">Odpowiadamy w ciągu 2h</p>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-coral-50 rounded-lg flex-shrink-0 flex items-center justify-center">
                <svg class="w-5 h-5 text-coral-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-slate-800 mb-1">Czas reakcji</h3>
                <p class="text-slate-600 font-medium">15 minut</p>
                <p class="text-sm text-slate-500 mt-1">Średnio tyle czekasz na oddzwonienie</p>
              </div>
            </div>
          </div>

          <div class="bg-teal-50 rounded-card p-6">
            <h3 class="font-heading font-semibold text-teal-800 mb-2">Dlaczego warto zadzwonić?</h3>
            <ul class="text-sm text-teal-700 space-y-2">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Konsultacja jest całkowicie bezpłatna
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Nie pobieramy żadnych opłat od klienta
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Porównamy oferty 30+ firm za Ciebie
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Bez zobowiązań — nie musisz nic podpisywać
              </li>
            </ul>
          </div>
        </div>

        <!-- Contact form -->
        <div class="lg:col-span-3">
          <div class="card !p-8">
            <h2 class="font-heading font-bold text-xl text-slate-800 mb-6">Napisz do nas</h2>
            <ContactForm client:visible variant="full" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://leasingpoprostu.pl/" },
      { "@type": "ListItem", "position": 2, "name": "Kontakt", "item": "https://leasingpoprostu.pl/kontakt/" }
    ]
  })} />
</BaseLayout>
