---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const faq = [
  { question: "Jakie dokumenty potrzebuje spółka z o.o. do leasingu?", answer: "KRS, umowa spółki, bilans i rachunek zysków i strat za ostatni rok (lub F-01 za ostatni kwartał), dowód właściciela/członka zarządu." },
  { question: "Czy nowa spółka z o.o. może wziąć leasing?", answer: "Tak — nawet od pierwszego dnia. Wkład własny będzie wyższy (15-30%), ale wiele firm leasingowych finansuje nowe spółki." },
  { question: "Czy spółka cywilna może wziąć leasing?", answer: "Tak — spółka cywilna może być stroną umowy leasingowej. Wymagane są dokumenty wszystkich wspólników plus umowa spółki." }
];
---
<ServiceLayout
  title="Leasing dla Spółki z o.o. 2026 — Warunki i Oferty | Ośmiorniczka"
  description="Leasing dla spółki z o.o. — warunki, dokumenty, oferty. Samochody, maszyny, sprzęt IT. Od 0% wkładu. Porównaj oferty 30+ firm."
  h1="Leasing dla spółki z o.o. — warunki i najlepsze oferty"
  subtitle="Spółki z o.o. to najczęstszy typ klienta firm leasingowych. Znamy specyfikę — pomożemy dobrać najlepszą ofertę."
  breadcrumbParent={{ name: "Dla kogo", url: "/dla-kogo/" }}
  breadcrumbCurrent="Spółka z o.o."
  faq={faq}
>
  <h2>Leasing dla sp. z o.o. — co musisz wiedzieć</h2>
  <p>Spółka z ograniczoną odpowiedzialnością to <strong>druga najpopularniejsza forma prawna</strong> wśród klientów leasingowych. Proces jest nieco bardziej formalny niż dla JDG, ale warunki często są lepsze — zwłaszcza dla spółek z obrotami.</p>
  <h3>Wymagane dokumenty</h3>
  <ul>
    <li><strong>KRS</strong> (aktualny odpis)</li>
    <li><strong>Umowa spółki</strong></li>
    <li><strong>Bilans + RZiS</strong> za ostatni rok obrotowy</li>
    <li><strong>F-01</strong> za ostatni kwartał (jeśli dostępny)</li>
    <li><strong>Dowód osobisty</strong> członka zarządu</li>
    <li><strong>Uchwała zarządu</strong> o zaciągnięciu zobowiązania (przy wyższych kwotach)</li>
  </ul>
  <h3>Korzyści leasingu dla sp. z o.o.</h3>
  <ul>
    <li>Raty leasingowe to <strong>koszt uzyskania przychodu</strong> (CIT)</li>
    <li>Leasing operacyjny jest <strong>pozabilansowy</strong> — nie zwiększa zadłużenia w bilansie</li>
    <li>Możliwość <strong>jednorazowej amortyzacji</strong> w leasingu finansowym (MŚP, do 50 000 EUR)</li>
    <li>Łatwiejsze uzyskanie niż kredyt bankowy</li>
  </ul>
</ServiceLayout>
