---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
const faq = [
  { question: "Jakie korzyści ma duża firma z brokera leasingu?", answer: "Duże firmy często mają umowy ramowe z kilkoma firmami leasingowymi. Broker może je rozszerzyć o dodatkowych partnerów i negocjować lepsze warunki dzięki łączeniu wolumenów wielu klientów." },
  { question: "Czy obsługujecie floty samochodowe?", answer: "Tak — pomagamy w finansowaniu całych flot. Od kilku do kilkudziesięciu pojazdów, z możliwością negocjacji warunków flotowych." }
];
---
<ServiceLayout
  title="Leasing dla Dużych Firm 2026 — Floty, Maszyny, Nieruchomości | Ośmiorniczka"
  description="Leasing dla dużych firm — floty samochodowe, linie produkcyjne, nieruchomości. Indywidualne warunki, dedykowany opiekun. Porównaj oferty."
  h1="Leasing dla dużych firm — indywidualne warunki"
  subtitle="Duża firma, duże potrzeby. Oferujemy dedykowaną obsługę, negocjacje indywidualnych warunków i finansowanie od kilkuset tysięcy do milionów złotych."
  breadcrumbParent={{ name: "Dla kogo", url: "/dla-kogo/" }}
  breadcrumbCurrent="Duże firmy"
  faq={faq}
>
  <h2>Finansowanie dla dużych firm</h2>
  <p>Duże firmy mają specyficzne potrzeby — wyższe kwoty, bardziej złożone struktury finansowania, wymagania compliance. Jako broker mamy doświadczenie w obsługiwaniu transakcji od setek tysięcy do milionów złotych.</p>
  <h3>Co oferujemy dużym firmom?</h3>
  <ul>
    <li><strong>Floty samochodowe</strong> — finansowanie 5-100+ pojazdów z warunkami flotowymi</li>
    <li><strong>Linie produkcyjne</strong> — leasing maszyn o wartości milionów złotych</li>
    <li><strong>Nieruchomości komercyjne</strong> — biura, hale, magazyny</li>
    <li><strong>Leasing zwrotny</strong> — uwolnienie kapitału z posiadanych aktywów</li>
    <li><strong>Structured finance</strong> — niestandardowe struktury finansowania</li>
  </ul>
  <h3>Dlaczego broker, a nie bezpośrednio?</h3>
  <ul>
    <li><strong>Więcej ofert</strong> — 30+ firm vs 2-3, z którymi macie umowę</li>
    <li><strong>Lepsze warunki</strong> — konkurencja między leasingodawcami = niższa cena</li>
    <li><strong>Oszczędność czasu</strong> — jeden kontakt zamiast kilkunastu</li>
    <li><strong>Bezpłatnie</strong> — bez dodatkowych kosztów</li>
  </ul>
</ServiceLayout>
