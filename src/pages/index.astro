---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm';
---

<BaseLayout
  title="Leasing i Kredyt Firmowy — Poradniki, Kalkulatory, Porównania | Ośmiorniczka"
  description="Darmowy portal edukacyjny o leasingu i kredytach firmowych. Poradniki, kalkulatory, porównania — bez rejestracji. Wszystko wyjaśnione po prostu."
>
  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #D1F5F4 0%, #FAFBFC 50%, #FFF0E6 100%);">
    <div class="container-wide py-16 md:py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="badge mb-4">Darmowy portal edukacyjny</div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-extrabold text-slate-900 mb-6 leading-[1.1]">
            Leasing i kredyt firmowy?<br/>
            <span class="text-teal-600">Wyjaśniamy to po prostu.</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-600 mb-8 max-w-lg leading-relaxed">
            Darmowa wiedza o leasingu i kredytach firmowych. <strong class="text-slate-800">Kalkulatory, poradniki, porównania</strong> — bez rejestracji, bez zobowiązań.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="/kalkulator-leasingu" class="btn-primary text-lg !py-4 !px-8">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z"/></svg>
              Oblicz ratę leasingu
            </a>
            <a href="/blog/" class="btn-secondary text-lg !py-4 !px-8">Czytaj poradniki</a>
          </div>
          <!-- Social proof -->
          <div class="flex flex-wrap items-center gap-6 text-sm text-slate-500">
            <div class="flex items-center gap-1.5">
              <div class="flex text-yellow-400">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              </div>
              <span>4.9/5 Google</span>
            </div>
            <span class="hidden sm:inline text-slate-300">|</span>
            <span>200+ artykułów i poradników</span>
            <span class="hidden sm:inline text-slate-300">|</span>
            <span>Darmowe kalkulatory</span>
          </div>
        </div>

        <!-- Hero visual -->
        <div class="hidden lg:flex justify-center">
          <div class="relative">
            <div class="absolute inset-0 bg-teal-200/30 rounded-full blur-3xl scale-150"></div>
            <img
              src="/osmiorniczka_bg.png"
              alt="Ośmiorniczka — maskotka portalu edukacyjnego o leasingu i kredytach firmowych"
              width="444"
              height="359"
              class="relative w-80 h-auto drop-shadow-xl"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="bg-white border-y border-slate-100 py-6">
    <div class="container-wide">
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 text-sm text-slate-400">
        <span class="font-medium">Porównujemy oferty m.in.:</span>
        <span class="font-heading font-semibold text-slate-500">mLeasing</span>
        <span class="font-heading font-semibold text-slate-500">PKO Leasing</span>
        <span class="font-heading font-semibold text-slate-500">Millennium</span>
        <span class="font-heading font-semibold text-slate-500">Santander</span>
        <span class="font-heading font-semibold text-slate-500">EFL</span>
        <span class="font-heading font-semibold text-slate-500">PEKAO</span>
        <span class="font-heading font-semibold text-slate-500">+24 inne</span>
      </div>
    </div>
  </section>

  <!-- What we do -->
  <section class="section-padding bg-[#FAFBFC]">
    <div class="container-wide">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-slate-900 mb-4">Czego szukasz?</h2>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto">Wybierz temat i dowiedz się wszystkiego, co musisz wiedzieć — prostym językiem.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card: Leasing -->
        <a href="/leasing/samochody/" class="card group">
          <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-teal-100 transition-colors">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h.844c.525 0 1.033-.19 1.428-.535l2.406-2.1a2.25 2.25 0 011.48-.555h3.692a2.25 2.25 0 011.575.645l2.7 2.7a2.25 2.25 0 001.59.66h1.33a.75.75 0 01.75.75v1.51a1.125 1.125 0 01-1.125 1.125h-.87"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2">Leasing</h3>
          <p class="text-sm text-slate-500 mb-3">Samochody, maszyny, sprzęt IT, fotowoltaika. Operacyjny i finansowy. Od 0% wkładu własnego.</p>
          <span class="text-sm font-semibold text-teal-600 group-hover:text-teal-700 inline-flex items-center gap-1">
            Dowiedz się więcej
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </span>
        </a>

        <!-- Card: Kredyt -->
        <a href="/kredyty/obrotowy/" class="card group">
          <div class="w-12 h-12 bg-coral-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-coral-100 transition-colors">
            <svg class="w-6 h-6 text-coral-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2">Kredyty firmowe</h3>
          <p class="text-sm text-slate-500 mb-3">Obrotowy, inwestycyjny, na start. Z gwarancją BGK. Przeczytaj, na co zwrócić uwagę.</p>
          <span class="text-sm font-semibold text-teal-600 group-hover:text-teal-700 inline-flex items-center gap-1">
            Czytaj poradnik
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </span>
        </a>

        <!-- Card: Faktoring -->
        <a href="/faktoring/" class="card group">
          <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-amber-100 transition-colors">
            <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-slate-800 mb-2">Faktoring</h3>
          <p class="text-sm text-slate-500 mb-3">Popraw płynność finansową firmy. Pieniądze z faktur w 24h. Pełny i niepełny.</p>
          <span class="text-sm font-semibold text-teal-600 group-hover:text-teal-700 inline-flex items-center gap-1">
            Dowiedz się więcej
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-slate-900 mb-4">Jak korzystać z portalu?</h2>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto">Wiedza, narzędzia i wsparcie — wszystko w jednym miejscu.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-teal-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-teal-600 font-heading font-bold text-2xl">1</div>
          <h3 class="font-heading font-bold text-slate-800 mb-2">Przeczytaj poradnik</h3>
          <p class="text-sm text-slate-500">Znajdź artykuł na interesujący Cię temat. Wszystko napisane prostym językiem.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-teal-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-teal-600 font-heading font-bold text-2xl">2</div>
          <h3 class="font-heading font-bold text-slate-800 mb-2">Użyj kalkulatora</h3>
          <p class="text-sm text-slate-500">Oblicz orientacyjną ratę leasingu lub kredytu. Bez rejestracji.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-teal-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-teal-600 font-heading font-bold text-2xl">3</div>
          <h3 class="font-heading font-bold text-slate-800 mb-2">Porównaj opcje</h3>
          <p class="text-sm text-slate-500">Zobacz, czym różnią się oferty i na co zwrócić uwagę.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-green-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-green-600 font-heading font-bold text-2xl">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          </div>
          <h3 class="font-heading font-bold text-slate-800 mb-2">Zdecyduj sam</h3>
          <p class="text-sm text-slate-500">Podejmij świadomą decyzję. A jeśli potrzebujesz pomocy — napisz do nas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator CTA -->
  <section class="section-padding" style="background: linear-gradient(135deg, #087F7D 0%, #0EA5A3 100%);">
    <div class="container-wide text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Oblicz ratę leasingu w 30 sekund</h2>
      <p class="text-lg text-teal-100 mb-8 max-w-2xl mx-auto">Darmowy kalkulator, bez rejestracji i bez żadnych zobowiązań. Sprawdź orientacyjną ratę i porównaj leasing z kredytem.</p>
      <a href="/kalkulator-leasingu" class="inline-flex items-center justify-center px-8 py-4 bg-white text-teal-700 font-heading font-bold rounded-xl shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 text-lg">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z"/></svg>
        Otwórz kalkulator
      </a>
    </div>
  </section>

  <!-- Leasing types -->
  <section class="section-padding bg-[#FAFBFC]">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-slate-900 mb-4">Co możesz leasingować?</h2>
        <p class="text-lg text-slate-500">Praktycznie wszystko, co potrzebujesz do prowadzenia firmy.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/leasing/samochody/" class="card group flex items-start gap-4">
          <div class="w-10 h-10 bg-teal-50 rounded-lg flex-shrink-0 flex items-center justify-center">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h.844c.525 0 1.033-.19 1.428-.535l2.406-2.1a2.25 2.25 0 011.48-.555h3.692a2.25 2.25 0 011.575.645l2.7 2.7a2.25 2.25 0 001.59.66h1.33a.75.75 0 01.75.75v1.51a1.125 1.125 0 01-1.125 1.125h-.87"/></svg>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Samochody</h3>
            <p class="text-sm text-slate-500">Osobowe, dostawcze, ciężarowe, elektryczne, używane</p>
          </div>
        </a>

        <a href="/leasing/maszyny/" class="card group flex items-start gap-4">
          <div class="w-10 h-10 bg-teal-50 rounded-lg flex-shrink-0 flex items-center justify-center">
            <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.049.58.025 1.194-.14 1.743"/></svg>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-slate-800 mb-1 group-hover:text-teal-600 transition-colors">Maszyny i urządzenia</h3>
            <p class="text-sm text-slate-500">CNC, budowlane, rolnicze, produkcyjne, medyczne</p>
          </div>
        </a>

        <a href="/leasing/it-sprzet/" class="card group flex items-start gap-4">
          <div class="w-10 h-10 bg-teal-50 rounded-lg flex-shrink-0 flex items-center justify-center">
