---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqCategories = [
  {
    title: "Leasing",
    items: [
      { q: "Co to jest leasing?", a: "Leasing to forma finansowania, w której firma leasingowa kupuje przedmiot (np. samochód, maszynę) i udostępnia go Twojej firmie w zamian za miesięczne raty. Po zakończeniu umowy możesz go wykupić." },
      { q: "Leasing operacyjny czy finansowy — co wybrać?", a: "Operacyjny jest popularniejszy — cała rata netto to koszt firmy i odliczasz VAT. Finansowy jest lepszy, jeśli chcesz być właścicielem od początku i amortyzować środek trwały." },
      { q: "Jaki jest minimalny okres leasingu?", a: "Dla leasingu operacyjnego minimalny okres to 24 miesiące (lub 40% normatywnego okresu amortyzacji). Dla finansowego nie ma ustawowego minimum." },
      { q: "Czy mogę wziąć leasing bez wkładu własnego?", a: "Tak — wiele firm leasingowych oferuje leasing od 0% wkładu. Wymagana jest dobra historia finansowa firmy." },
      { q: "Co się dzieje po zakończeniu leasingu?", a: "W leasingu operacyjnym możesz wykupić przedmiot za wartość rezydualną (1-15%) lub go zwrócić. W finansowym — własność przechodzi na Ciebie automatycznie." },
      { q: "Czy leasing można spłacić wcześniej?", a: "Tak, ale większość firm leasingowych pobiera prowizję za wcześniejszy wykup (zwykle 1-3% pozostałej kwoty). Warto to sprawdzić przed podpisaniem umowy." },
    ]
  },
  {
    title: "Kredyty firmowe",
    items: [
      { q: "Jaka jest różnica między leasingiem a kredytem?", a: "W leasingu przedmiot należy do firmy leasingowej (Ty go używasz), w kredycie — kupujesz na siebie. Leasing jest szybszy, łatwo dostępny i optymalny podatkowo. Kredyt daje własność od razu." },
      { q: "Czy nowa firma może dostać kredyt?", a: "Jest to trudniejsze niż leasing, ale możliwe — zwłaszcza z gwarancją BGK de minimis. Minimum 3-6 miesięcy działalności." },
      { q: "Co to jest gwarancja BGK de minimis?", a: "To bezpłatne zabezpieczenie kredytu przez Bank Gospodarstwa Krajowego (do 80% kwoty). Ułatwia uzyskanie finansowania i może obniżać oprocentowanie." },
      { q: "Jakie dokumenty potrzebuję do kredytu firmowego?", a: "Dowód osobisty, NIP, deklaracje podatkowe (PIT/CIT), sprawozdania finansowe. Dla mikrofirm — KPiR lub ewidencja przychodów." },
    ]
  },
  {
    title: "O naszych usługach",
    items: [
      { q: "Ile kosztują usługi brokera?", a: "Nic — nasze usługi są całkowicie bezpłatne dla klienta. Wynagrodzenie otrzymujemy od firm leasingowych i banków." },
      { q: "Jak długo trwa proces?", a: "Oddzwaniamy w 15 minut, oferty masz w ciągu godziny, decyzja leasingowa w 24-48h. Cały proces od zapytania do podpisania umowy to 3-7 dni roboczych." },
      { q: "Z iloma firmami współpracujecie?", a: "Współpracujemy z ponad 30 firmami leasingowymi i bankami w Polsce, w tym mLeasing, PKO Leasing, Millennium, Santander, EFL, PEKAO i wieloma innymi." },
      { q: "Czy mogę zobaczyć oferty przed podjęciem decyzji?", a: "Oczywiście — przedstawiamy 3-5 najlepszych ofert z pełnym porównaniem (rata, koszt całkowity, warunki). Ty decydujesz, którą wybrać. Bez presji." },
    ]
  }
];

const allFaqItems = faqCategories.flatMap(cat =>
  cat.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
);
---

<BaseLayout
  title="FAQ — Często Zadawane Pytania o Leasing i Kredyt | Ośmiorniczka"
  description="Odpowiedzi na najczęściej zadawane pytania o leasing, kredyty firmowe, faktoring i nasze usługi brokerskie. Wszystko co musisz wiedzieć."
>
  <section class="section-padding bg-[#FAFBFC]">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-heading font-bold text-slate-900 mb-4">Często zadawane pytania</h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto">Odpowiedzi na najpopularniejsze pytania o leasing, kredyty i nasze usługi.</p>
      </div>

      {faqCategories.map((category) => (
        <div class="mb-10">
          <h2 class="text-2xl font-heading font-bold text-slate-900 mb-4">{category.title}</h2>
          <div class="space-y-3">
            {category.items.map((item, i) => (
              <details class="card group" open={i === 0}>
                <summary class="font-heading font-semibold text-slate-800 cursor-pointer list-none flex items-center justify-between">
                  {item.q}
                  <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
                </summary>
                <p class="text-slate-600 mt-3">{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      ))}

      <div class="bg-gradient-to-br from-teal-50 via-white to-coral-50 rounded-3xl border border-slate-200 p-8 text-center mt-12">
        <h2 class="text-2xl font-heading font-bold text-slate-900 mb-3">Nie znalazłeś odpowiedzi?</h2>
        <p class="text-slate-500 mb-6">Zadzwoń lub napisz — chętnie odpowiemy na każde pytanie.</p>
        <a href="/kontakt/" class="btn-primary">Skontaktuj się z nami</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": allFaqItems
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://osmiorniczka.pl/" },
      { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://osmiorniczka.pl/faq/" }
    ]
  })} />
</BaseLayout>
