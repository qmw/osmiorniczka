---
import ServiceLayout from '../layouts/ServiceLayout.astro';
const faq = [
  { question: "Co to jest faktoring?", answer: "Faktoring to usługa finansowa, w której firma faktoringowa wypłaca Ci pieniądze z wystawionych faktur przed terminem płatności. Zamiast czekać 30-90 dni, dostajesz środki w 24 godziny." },
  { question: "Ile kosztuje faktoring?", answer: "Prowizja faktoringowa wynosi zazwyczaj 0,1-3% wartości faktury. Koszt zależy od wolumenu, terminów płatności i ryzyka kontrahenta." },
  { question: "Czym się różni faktoring pełny od niepełnego?", answer: "W faktoringu pełnym firma faktoringowa przejmuje ryzyko niepłacenia przez kontrahenta. W niepełnym — jeśli kontrahent nie zapłaci, Ty zwracasz pieniądze faktorowi." },
  { question: "Czy mała firma może korzystać z faktoringu?", answer: "Tak — faktoring jest dostępny nawet dla małych firm z obrotem od 50 000 zł miesięcznie. Nie trzeba mieć długiej historii działalności." }
];
---
<ServiceLayout
  title="Faktoring dla Firm 2026 — Pieniądze z Faktur w 24h | Ośmiorniczka"
  description="Faktoring dla firm — pieniądze z faktur w 24 godziny. Pełny i niepełny, od 0,1% prowizji. Popraw płynność finansową. Porównaj oferty faktorów."
  h1="Faktoring — pieniądze z faktur w 24 godziny"
  subtitle="Nie czekaj 30-90 dni na płatność od kontrahenta. Faktoring pozwala otrzymać środki z wystawionych faktur w ciągu jednego dnia roboczego."
  heroImage="/faktoring-hero.png"
  breadcrumbCurrent="Faktoring"
  faq={faq}
>
  <h2>Faktoring — jak działa?</h2>
  <ol>
    <li><strong>Wystawiasz fakturę</strong> kontrahentowi z odroczonym terminem płatności</li>
    <li><strong>Przesyłasz fakturę</strong> do firmy faktoringowej</li>
    <li><strong>Otrzymujesz 80-90% kwoty</strong> na konto w 24 godziny</li>
    <li><strong>Kontrahent płaci</strong> faktorowi w terminie</li>
    <li><strong>Otrzymujesz resztę</strong> (pomniejszoną o prowizję faktora)</li>
  </ol>

  <h3>Rodzaje faktoringu</h3>
  <table>
    <thead><tr><th>Rodzaj</th><th>Ryzyko niewykładu</th><th>Koszt</th><th>Dla kogo</th></tr></thead>
    <tbody>
      <tr><td>Pełny (bez regresu)</td><td>Faktor</td><td>Wyższy</td><td>Firmy z wieloma kontrahentami</td></tr>
      <tr><td>Niepełny (z regresem)</td><td>Twoja firma</td><td>Niższy</td><td>Firmy ze stałymi, pewnymi odbiorcami</td></tr>
      <tr><td>Odwrotny</td><td>Faktor</td><td>Średni</td><td>Opłacanie własnych faktur zakupowych</td></tr>
      <tr><td>Cichy</td><td>Twoja firma</td><td>Niższy</td><td>Gdy nie chcesz informować kontrahenta</td></tr>
    </tbody>
  </table>

  <h3>Kiedy warto rozważyć faktoring?</h3>
  <ul>
    <li>Kontrahenci płacą z <strong>odroczonym terminem</strong> (30-90 dni)</li>
    <li>Potrzebujesz <strong>stałego dostępu do gotówki</strong></li>
    <li>Firma szybko rośnie i <strong>brakuje kapitału obrotowego</strong></li>
    <li>Nie chcesz zaciągać kredytu bankowego</li>
    <li>Masz <strong>wiarygodnych kontrahentów</strong> (korporacje, instytucje publiczne)</li>
  </ul>

  <h3>Faktoring vs kredyt obrotowy</h3>
  <table>
    <thead><tr><th>Aspekt</th><th>Faktoring</th><th>Kredyt obrotowy</th></tr></thead>
    <tbody>
      <tr><td>Zabezpieczenie</td><td>Faktury (wierzytelności)</td><td>Hipoteka, poręczenie, BGK</td></tr>
      <tr><td>Szybkość uruchomienia</td><td>1-3 dni</td><td>1-4 tygodnie</td></tr>
      <tr><td>Limit rośnie z obrotami</td><td>Tak</td><td>Stały</td></tr>
      <tr><td>Wpływ na bilans</td><td>Minimalny</td><td>Zwiększa zadłużenie</td></tr>
      <tr><td>Dla nowych firm</td><td>Tak (od 3 mies.)</td><td>Trudne (min. 12 mies.)</td></tr>
    </tbody>
  </table>
</ServiceLayout>
