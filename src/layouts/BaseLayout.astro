---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  type = 'website',
  publishedDate,
  modifiedDate,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://osmiorniczka.pl';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const fullOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;
const siteName = 'Ośmiorniczka.pl';
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="pl_PL" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  {publishedDate && <meta property="article:published_time" content={publishedDate} />}
  {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Schema.org LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": "Ośmiorniczka - Broker Leasingu i Kredytów",
    "description": "Niezależny broker leasingu i kredytów firmowych. Porównujemy oferty 30+ firm leasingowych i banków.",
    "url": siteUrl,
    "logo": `${siteUrl}/logo.svg`,
    "telephone": "+48-XXX-XXX-XXX",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "PL"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Poland"
    },
    "serviceType": ["Leasing", "Kredyt firmowy", "Faktoring"],
    "priceRange": "$$"
  })} />

  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col">
  <slot name="header">
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-200/60">
      <nav class="container-wide flex items-center justify-between h-16 md:h-18">
        <a href="/" class="flex items-center gap-2 group" aria-label="Strona główna Ośmiorniczka">
          <img src="/favicon.svg" alt="Ośmiorniczka" width="36" height="36" class="w-9 h-9 group-hover:scale-110 transition-transform" />
          <span class="font-heading font-bold text-xl text-slate-800">Ośmiorniczka</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1">
          <a href="/kalkulator-leasingu" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-teal-600 rounded-lg hover:bg-teal-50/50 transition-colors">Kalkulator</a>
          <a href="/leasing/samochody/" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-teal-600 rounded-lg hover:bg-teal-50/50 transition-colors">Leasing</a>
          <a href="/kredyty/obrotowy/" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-teal-600 rounded-lg hover:bg-teal-50/50 transition-colors">Kredyty</a>
          <a href="/faktoring/" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-teal-600 rounded-lg hover:bg-teal-50/50 transition-colors">Faktoring</a>
          <a href="/blog/" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-teal-600 rounded-lg hover:bg-teal-50/50 transition-colors">Blog</a>
          <a href="/o-mnie/" class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-teal-600 rounded-lg hover:bg-teal-50/50 transition-colors">O mnie</a>
        </div>

        <div class="hidden md:flex items-center gap-3">
          <a href="tel:+48000000000" class="text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors">
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              Zadzwoń
            </span>
          </a>
          <a href="/kontakt/" class="btn-primary text-sm !py-2.5 !px-5">Bezpłatna konsultacja</a>
        </div>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-teal-600" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
          </svg>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white pb-4">
        <div class="container-wide flex flex-col gap-1 pt-2">
          <a href="/kalkulator-leasingu" class="px-3 py-2.5 text-sm font-medium text-slate-600 hover:text-teal-600 hover:bg-teal-50/50 rounded-lg">Kalkulator leasingu</a>
          <a href="/leasing/samochody/" class="px-3 py-2.5 text-sm font-medium text-slate-600 hover:text-teal-600 hover:bg-teal-50/50 rounded-lg">Leasing</a>
          <a href="/kredyty/obrotowy/" class="px-3 py-2.5 text-sm font-medium text-slate-600 hover:text-teal-600 hover:bg-teal-50/50 rounded-lg">Kredyty</a>
          <a href="/faktoring/" class="px-3 py-2.5 text-sm font-medium text-slate-600 hover:text-teal-600 hover:bg-teal-50/50 rounded-lg">Faktoring</a>
          <a href="/blog/" class="px-3 py-2.5 text-sm font-medium text-slate-600 hover:text-teal-600 hover:bg-teal-50/50 rounded-lg">Blog</a>
          <a href="/o-mnie/" class="px-3 py-2.5 text-sm font-medium text-slate-600 hover:text-teal-600 hover:bg-teal-50/50 rounded-lg">O mnie</a>
          <a href="/kontakt/" class="btn-primary text-sm mt-2 text-center">Bezpłatna konsultacja</a>
        </div>
      </div>
    </header>
  </slot>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-slate-900 text-slate-300">
    <div class="container-wide section-padding">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
        <!-- Brand -->
        <div>
          <div class="flex items-center gap-2 mb-4">
            <img src="/favicon.svg" alt="Ośmiorniczka" width="32" height="32" class="w-8 h-8" />
            <span class="font-heading font-bold text-lg text-white">Ośmiorniczka</span>
          </div>
          <p class="text-sm text-slate-400 mb-4">Niezależny broker leasingu i kredytów firmowych. Porównujemy oferty 30+ firm leasingowych i banków — znajdziemy najtańszą.</p>
          <p class="text-xs text-slate-500">"Wiele ramion, jedno rozwiązanie"</p>
        </div>

        <!-- Leasing -->
        <div>
          <h4 class="font-heading font-semibold text-white text-sm mb-4 uppercase tracking-wider">Leasing</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/leasing/samochody/" class="hover:text-teal-400 transition-colors">Leasing samochodu</a></li>
            <li><a href="/leasing/maszyny/" class="hover:text-teal-400 transition-colors">Leasing maszyn</a></li>
            <li><a href="/leasing/it-sprzet/" class="hover:text-teal-400 transition-colors">Leasing sprzętu IT</a></li>
            <li><a href="/leasing/fotowoltaika/" class="hover:text-teal-400 transition-colors">Leasing fotowoltaiki</a></li>
            <li><a href="/leasing/nieruchomosci/" class="hover:text-teal-400 transition-colors">Leasing nieruchomości</a></li>
            <li><a href="/leasing/zwrotny/" class="hover:text-teal-400 transition-colors">Leasing zwrotny</a></li>
          </ul>
        </div>

        <!-- Kredyty & inne -->
        <div>
          <h4 class="font-heading font-semibold text-white text-sm mb-4 uppercase tracking-wider">Finansowanie</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/kredyty/obrotowy/" class="hover:text-teal-400 transition-colors">Kredyt obrotowy</a></li>
            <li><a href="/kredyty/inwestycyjny/" class="hover:text-teal-400 transition-colors">Kredyt inwestycyjny</a></li>
            <li><a href="/kredyty/na-start/" class="hover:text-teal-400 transition-colors">Kredyt na start</a></li>
            <li><a href="/kredyty/z-gwarancja-bgk/" class="hover:text-teal-400 transition-colors">Gwarancja BGK</a></li>
            <li><a href="/faktoring/" class="hover:text-teal-400 transition-colors">Faktoring</a></li>
          </ul>
        </div>

        <!-- Info -->
        <div>
          <h4 class="font-heading font-semibold text-white text-sm mb-4 uppercase tracking-wider">Informacje</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/kalkulator-leasingu" class="hover:text-teal-400 transition-colors">Kalkulator leasingu</a></li>
            <li><a href="/blog/" class="hover:text-teal-400 transition-colors">Blog</a></li>
            <li><a href="/o-mnie/" class="hover:text-teal-400 transition-colors">O mnie</a></li>
            <li><a href="/kontakt/" class="hover:text-teal-400 transition-colors">Kontakt</a></li>
            <li><a href="/faq/" class="hover:text-teal-400 transition-colors">FAQ</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-xs text-slate-500">&copy; {new Date().getFullYear()} Ośmiorniczka.pl — Niezależny broker leasingu i kredytów. Wszelkie prawa zastrzeżone.</p>
        <div class="flex gap-6 text-xs text-slate-500">
          <a href="/polityka-prywatnosci/" class="hover:text-slate-300 transition-colors">Polityka prywatności</a>
          <a href="/regulamin/" class="hover:text-slate-300 transition-colors">Regulamin</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
