---
import BaseLayout from './BaseLayout.astro';
import ContactForm from '../components/ContactForm';

interface Props {
  title: string;
  description: string;
  h1: string;
  subtitle: string;
  heroImage?: string;
  heroAlt?: string;
  breadcrumbParent?: { name: string; url: string };
  breadcrumbCurrent: string;
  faq?: Array<{ question: string; answer: string }>;
}

const { title, description, h1, subtitle, heroImage, heroAlt, breadcrumbParent, breadcrumbCurrent, faq = [] } = Astro.props;

const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://leasingpoprostu.pl/" }
];
if (breadcrumbParent) {
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": 2,
    "name": breadcrumbParent.name,
    "item": `https://leasingpoprostu.pl${breadcrumbParent.url}`
  });
}
breadcrumbItems.push({
  "@type": "ListItem",
  "position": breadcrumbItems.length + 1,
  "name": breadcrumbCurrent,
  "item": `https://leasingpoprostu.pl${Astro.url.pathname}`
});
---

<BaseLayout title={title} description={description}>
  <!-- Breadcrumbs -->
  <nav class="bg-white border-b border-slate-100 py-3" aria-label="Breadcrumb">
    <div class="container-wide">
      <ol class="flex items-center gap-2 text-sm text-slate-500">
        <li><a href="/" class="hover:text-teal-600 transition-colors">Strona główna</a></li>
        {breadcrumbParent && (
          <>
            <li><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></li>
            <li><a href={breadcrumbParent.url} class="hover:text-teal-600 transition-colors">{breadcrumbParent.name}</a></li>
          </>
        )}
        <li><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg></li>
        <li class="text-slate-800 font-medium">{breadcrumbCurrent}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="py-12 md:py-20" style="background: linear-gradient(135deg, #EEF3FB 0%, #FAFBFC 100%);">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-slate-900 mb-4">{h1}</h1>
        <p class="text-lg text-slate-600 mb-6">{subtitle}</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/kalkulator-leasingu" class="btn-primary">Oblicz ratę</a>
          <a href="/kontakt/" class="btn-secondary">Napisz do nas</a>
        </div>
      </div>
      {heroImage && (
        <img src={heroImage} alt={heroAlt || h1} class="rounded-2xl mt-8 w-full max-w-md mx-auto" />
      )}
    </div>
  </section>

  <!-- Main content -->
  <section class="section-padding bg-white">
    <div class="container-narrow prose">
      <slot />
    </div>
  </section>

  <!-- FAQ if provided -->
  {faq.length > 0 && (
    <section class="section-padding bg-[#FAFBFC]">
      <div class="container-narrow">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-slate-900 mb-8 text-center">Często zadawane pytania</h2>
        <div class="space-y-4">
          {faq.map((item, i) => (
            <details class="card group" open={i === 0}>
              <summary class="font-heading font-semibold text-slate-800 cursor-pointer list-none flex items-center justify-between">
                {item.question}
                <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
              </summary>
              <p class="text-slate-600 mt-3">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="bg-gradient-to-br from-teal-50 via-white to-coral-50 rounded-3xl border border-slate-200 p-8 md:p-12">
        <div class="text-center mb-8">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-slate-900 mb-3">Masz pytanie?</h2>
          <p class="text-slate-500">Napisz lub zadzwoń — chętnie pomożemy. Zero zobowiązań.</p>
        </div>
        <div class="max-w-lg mx-auto">
          <ContactForm client:visible variant="compact" />
        </div>
      </div>
    </div>
  </section>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems
  })} />

  <!-- FAQ Schema -->
  {faq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })} />
  )}
</BaseLayout>
